<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Electron apps -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required for Electron's V8 JavaScript engine -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow loading Electron Framework signed by a different Team ID -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Audio input for microphone recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Accessibility APIs (paste, text monitoring) -->
    <key>com.apple.security.temporary-exception.accessibility</key>
    <true/>
</dict>
</plist>